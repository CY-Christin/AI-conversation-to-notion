# ──────────────────────────────────────────────────────────────────
# 开发 / 测试用环境变量模板。复制为 .env 后填写。
#
# ⚠️ 注意：插件【运行时】的 Notion 凭据不在这里！
#    用户的 token 由插件设置页输入，存进 chrome.storage，永不进仓库。
#    本文件只服务于本地集成测试 / 构建脚本，绝不打包进发布产物。
# ──────────────────────────────────────────────────────────────────

# 本地集成测试用的 Notion internal integration token（形如 ntn_xxx / secret_xxx）
NOTION_TOKEN=

# 测试用根 page id（即 "AI Conversations" 那个 page 的 ID）
NOTION_ROOT_PAGE_ID=
